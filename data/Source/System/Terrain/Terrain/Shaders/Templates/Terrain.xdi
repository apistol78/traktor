		<item type="traktor.render.Script" version="8,traktor.render.Node:1">
			<id>{2BD768C2-6224-7F4E-84F5-2735B266A95E}</id>
			<comment/>
			<position>
				<first>3987</first>
				<second>-2432</second>
			</position>
			<name>Overlay</name>
			<technique/>
			<domain>Undefined</domain>
			<localSize>
				<X>1</X>
				<Y>1</Y>
				<Z>1</Z>
			</localSize>
			<useRayTracing>false</useRayTracing>
			<include/>
			<inputPins>
				<item>
					<id>{52A043E1-22B9-C742-A1A6-8341D043284F}</id>
					<name>A</name>
				</item>
				<item>
					<id>{51E30CE0-3C94-4668-AC3A-2CE903530D64}</id>
					<name>B</name>
				</item>
			</inputPins>
			<outputPins>
				<item>
					<id>{4F792F72-F9F9-A945-8CAE-8F4EEEE77624}</id>
					<name>Output</name>
					<type>Vector</type>
				</item>
			</outputPins>
			<script><![CDATA[
			
const vec3 f = step($B, vec3(0.5f));
const vec3 t = 1.0f - 2.0f * (1.0f - $A) * (1.0f - $B);
const vec3 b = 2.0f * $A * $B;
$Output = vec4(mix(t, b, f), 0.0f);
			
			]]></script>
		</item>
		<item type="traktor.render.Variable" version="2,traktor.render.Node:1">
			<id>{921A32F1-E7B3-E04C-A243-F637F6027577}</id>
