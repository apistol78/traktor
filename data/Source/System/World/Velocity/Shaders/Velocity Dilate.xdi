		<item type="traktor.render.Script" version="8,traktor.render.Node:1">
			<id>{262FB4B7-E519-4BA8-9C4E-7ADE6787CF79}</id>
			<comment/>
			<position>
				<first>2671</first>
				<second>1546</second>
			</position>
			<name>Search</name>
			<technique/>
			<domain>Undefined</domain>
			<localSize>
				<X>1</X>
				<Y>1</Y>
				<Z>1</Z>
			</localSize>
			<useRayTracing>false</useRayTracing>
			<include/>
			<inputPins>
				<item>
					<id>{B799A214-0B0E-4E60-8E7E-6A977F9E8131}</id>
					<name>TexCoord</name>
				</item>
				<item>
					<id>{3FB90CF4-204E-4F61-8A93-86A8715B9686}</id>
					<name>DepthTexture</name>
				</item>
				<item>
					<id>{86E35458-7498-4258-8EC4-D93DAAB2D2BB}</id>
					<name>VelocityTexture</name>
				</item>
				<item>
					<id>{376E949C-AF0F-4A60-994B-E3903E68CAAC}</id>
					<name>OutputSize</name>
				</item>
				<item>
					<id>{E06F7D5E-26C2-46FD-BC59-E19C5EDBFD80}</id>
					<name>Sampler</name>
				</item>
			</inputPins>
			<outputPins>
				<item>
					<id>{C7C58F2C-AED9-4606-85F2-14F42CEF62B9}</id>
					<name>Output</name>
					<type>Vector</type>
				</item>
			</outputPins>
			<script><![CDATA[
vec2 minV = vec2(0.0f, 0.0f);
float minD = 1e8f;

for (int iy = -1; iy <= 1; ++iy)
{
	for (int ix = -1; ix <= 1; ++ix)
	{
		const vec2 duv = vec2(ix, iy) / $OutputSize.xy;
		const vec2 uv = $TexCoord.xy + duv;
		const float d = texture(sampler2D($DepthTexture, $Sampler), uv).x;
		if (d < minD)
		{
			minV = texture(sampler2D($VelocityTexture, $Sampler), uv).xy;
			minD = d;
		}
	}
}

$Output = vec4(minV, 0, 0);
]]></script>
		</item>
