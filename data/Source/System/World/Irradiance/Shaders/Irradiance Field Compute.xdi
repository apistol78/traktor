<object type="traktor.render.ShaderGraph" version="traktor.render.Graph:1">
	<nodes>
		<item type="traktor.render.Script" version="8,traktor.render.Node:1">
			<id>{A468EB82-EAA9-AE43-969E-013DCCE6AC18}</id>
			<comment/>
			<position>
				<first>-1672</first>
				<second>-215</second>
			</position>
			<name>Pass</name>
			<technique>Default</technique>
			<domain>Compute</domain>
			<localSize>
				<X>8</X>
				<Y>8</Y>
				<Z>8</Z>
			</localSize>
			<useRayTracing>true</useRayTracing>
			<include>
				<item>{4370C471-3C5D-914B-A3AC-866BE15AD328}</item>
				<item>{6ED30419-6A30-3D41-9583-D6E71FFE0064}</item>
				<item>{0E3643A0-A0DA-B649-9FD8-930F4EB6D42A}</item>
				<item>{1C13688E-63BC-3141-ACB1-58EEE72EEF2F}</item>
				<item>{921BBC45-4C75-624A-AA78-9B5FEC80645B}</item>
				<item>{F6048A61-5C30-204E-8ACC-D203978866C8}</item>
			</include>
			<inputPins>
				<item>
					<id>{EADA77CC-17C7-41D7-B0E1-8D59463CCDD6}</id>
					<name>Output</name>
				</item>
				<item>
					<id>{41A91F91-0E23-B74A-8D5B-14716C7412D5}</id>
					<name>AS</name>
				</item>
				<item>
					<id>{014DA7E5-18F0-8D49-AD7C-CBE5689F001E}</id>
					<name>Lights</name>
				</item>
				<item>
					<id>{B63DD5AC-E9B0-AA4C-9FD2-E8B0CD4DEF98}</id>
					<name>LightCount</name>
				</item>
				<item>
					<id>{CED9EC33-5AE5-6541-964F-107108C02751}</id>
					<name>ViewInverse</name>
				</item>
				<item>
					<id>{E6B53F89-364B-2C40-A08C-91CCE471354E}</id>
					<name>Random</name>
				</item>
				<item>
					<id>{D518FD9D-7908-F441-893E-EB695A069EF2}</id>
					<name>LastIrradianceField</name>
				</item>
				<item>
					<id>{08D46483-83DB-B640-88F4-E221D06E1420}</id>
					<name>LastViewInverse</name>
				</item>
			</inputPins>
			<outputPins/>
			<script><![CDATA[
const int N = 16;
const float Far = 70.0f;
const float TemporalFilter = 0.99f;

const ivec3 pt = ivec3(gl_GlobalInvocationID.xyz);
const vec3 cellPosition = CellToWorldSpace($ViewInverse, pt);

const vec3 Nacc0 = SampleIrradianceField($LastIrradianceField, $LastViewInverse, cellPosition);

vec3 Nacc = vec3(0.0f, 0.0f, 0.0f);

int sampleOffset = int($Random * 256 / N);
int rndState = int($Random * 768);

for (int i = 0; i < N; ++i)
{
	const vec2 rnd = Hammersley(sampleOffset++ & 255, 256);

	const vec3 ro = vec3(
		(Hash(rndState++) * 2.0f - 1.0f) * CellExtent,
		(Hash(rndState++) * 2.0f - 1.0f) * CellExtent,
		(Hash(rndState++) * 2.0f - 1.0f) * CellExtent
	);

	const vec3 rayDir = Sphere(rnd);
	const vec3 rayOrigin = cellPosition + ro;

	HWRT_Material m;
	float t;

	if (HWRT_Trace($AS, rayOrigin, rayDir, Far, m, t))
	{
		const vec3 hit = rayOrigin + rayDir * t;
		const float attenuate = LightAttenuation(t);
		
		for (int lightIndex = 0; lightIndex < $LightCount; ++lightIndex)
		{
			const $typeof(Lights) light = $Lights[lightIndex];
			const vec4 incident = HWRT_Light_CalculateIncidentLight(
				$AS,
				$ViewInverse,
				light,
				hit,
				m.normal.xyz,
				true
			);
			Nacc += incident.xyz * attenuate;
		}
	}
}
Nacc /= float(N);

Nacc = Nacc * (1.0f - TemporalFilter) + Nacc0 * TemporalFilter;

imageStore($Output, pt, vec4(Nacc, 0.0f));

]]></script>
		</item>
