		<item type="traktor.render.Script" version="8,traktor.render.Node:1">
			<id>{1DBA7EBD-D42C-BE43-A4EB-98A34AAFF868}</id>
			<comment/>
			<position>
				<first>998</first>
				<second>858</second>
			</position>
			<name>CalculateReflection</name>
			<technique/>
			<domain>Undefined</domain>
			<localSize>
				<X>1</X>
				<Y>1</Y>
				<Z>1</Z>
			</localSize>
			<useRayTracing>false</useRayTracing>
			<include>
				<item>{8541C8B0-4A05-AA42-BFE7-7DBF639AAF8B}</item>
			</include>
			<inputPins>
				<item>
					<id>{E3D5AF2E-3627-FC46-A087-DC20C3905FB0}</id>
					<name>N</name>
				</item>
				<item>
					<id>{31FFA9B7-3CC6-5F48-B1ED-D69380BE139A}</id>
					<name>V</name>
				</item>
				<item>
					<id>{3553EE66-88F5-2C4B-9093-6E0AF2F80480}</id>
					<name>Albedo</name>
				</item>
				<item>
					<id>{CD77DAB2-298A-A04F-BA9E-C535D9F7039D}</id>
					<name>Metallic</name>
				</item>
				<item>
					<id>{B73BE704-2E99-A143-9DFC-3738157E107D}</id>
					<name>Roughness</name>
				</item>
			</inputPins>
			<outputPins>
				<item>
					<id>{26124FFB-5851-A149-800A-2611E58573AD}</id>
					<name>Output</name>
					<type>Vector</type>
				</item>
			</outputPins>
			<script><![CDATA[
			
const vec3 N = $N.xyz;
const vec3 V = $V.xyz;
const vec3 albedo = $Albedo.xyz;
const float metallic = $Metallic.x;
const float roughness = $Roughness.x;

const vec3 r = CalculateReflection(
	N,
	V,
	albedo,
	metallic,
	roughness
);

$Output = vec4(r, 0.0f);

			
			]]></script>
		</item>
