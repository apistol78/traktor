		<item type="traktor.render.Script" version="8,traktor.render.Node:1">
			<id>{09E5FCEB-DF24-624E-B871-1ECDFCD7A8B9}</id>
			<comment/>
			<position>
				<first>-403</first>
				<second>113</second>
			</position>
			<name>GetSlice</name>
			<technique/>
			<domain>Undefined</domain>
			<localSize>
				<X>1</X>
				<Y>1</Y>
				<Z>1</Z>
			</localSize>
			<useRayTracing>false</useRayTracing>
			<include/>
			<inputPins>
				<item>
					<id>{1DF0A7F6-939F-4341-B9FA-5E76341B831F}</id>
					<name>Input</name>
				</item>
				<item>
					<id>{2EBBD4FC-E7B9-4465-B180-870FE37214D1}</id>
					<name>SlicePositions</name>
				</item>
			</inputPins>
			<outputPins>
				<item>
					<id>{EC60178B-E080-C149-A661-9C5B889EA38D}</id>
					<name>Output</name>
					<type>Scalar</type>
				</item>
			</outputPins>
			<script><![CDATA[
			
const vec4 sp = $SlicePositions;
const float vz = $Input.z;

if (vz >= sp.z)
	$Output = 3;
else if (vz >= sp.y)
	$Output = 2;
else if (vz >= sp.x)
	$Output = 1;
else
	$Output = 0;
			
			]]></script>
		</item>
