		<item type="traktor.render.Script" version="8,traktor.render.Node:1">
			<id>{AF10E59E-248D-434D-901A-F22C29885AC2}</id>
			<comment/>
			<position>
				<first>-807</first>
				<second>803</second>
			</position>
			<name>Mie Scattering Phase</name>
			<technique/>
			<domain>Undefined</domain>
			<localSize>
				<X>1</X>
				<Y>1</Y>
				<Z>1</Z>
			</localSize>
			<useRayTracing>false</useRayTracing>
			<include/>
			<inputPins>
				<item>
					<id>{0D22C808-9FE4-B548-89F0-8D6BF18DBFCF}</id>
					<name>Input</name>
				</item>
			</inputPins>
			<outputPins>
				<item>
					<id>{444C9199-3D65-514B-B3F3-EF9295325ED3}</id>
					<name>Output</name>
					<type>Scalar</type>
				</item>
			</outputPins>
			<script><![CDATA[
const float G = 0.7;
const float PI = 3.142f;
const float cosTheta = $Input;
$Output = (1.0f - G * G) / (4.0f * PI * pow(1.0f + G * G - 2.0f * G * cosTheta, 1.5f));
			]]></script>
		</item>
