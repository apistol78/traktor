		<item type="traktor.render.Script" version="8,traktor.render.Node:1">
			<id>{5392FB12-61CC-4244-9B2C-B30F51F5A0BD}</id>
			<comment/>
			<position>
				<first>336</first>
				<second>-632</second>
			</position>
			<name>ViewspaceToFrustumCellNDC</name>
			<technique/>
			<domain>Undefined</domain>
			<localSize>
				<X>1</X>
				<Y>1</Y>
				<Z>1</Z>
			</localSize>
			<useRayTracing>false</useRayTracing>
			<include>
				<item>{328E6693-7B5B-5B4F-AC6B-987ECADAE330}</item>
			</include>
			<inputPins>
				<item>
					<id>{6555AF5E-69B9-2147-A90C-1E6220A22100}</id>
					<name>VolumeSize</name>
				</item>
				<item>
					<id>{79BAF5AF-B891-3D4E-B2E7-CD0F7C03AEC1}</id>
					<name>MagicCoeffs</name>
				</item>
				<item>
					<id>{FEC7D688-4B39-AC46-AF38-B4D6412CFFB3}</id>
					<name>NearZ</name>
				</item>
				<item>
					<id>{ADA5C76A-DB22-EA40-8133-B2A9979C5A07}</id>
					<name>FarZ</name>
				</item>
				<item>
					<id>{D5630BB7-FC83-7640-9DB2-CFB485EFD5A6}</id>
					<name>ViewPosition</name>
				</item>
			</inputPins>
			<outputPins>
				<item>
					<id>{72D7AC3C-9B4B-5142-93FB-40DC055DDADE}</id>
					<name>Output</name>
					<type>Vector</type>
				</item>
				<item>
					<id>{FD3E7F3F-858F-4FF9-8474-0B3A301EB1C6}</id>
					<name>Valid</name>
					<type>Scalar</type>
				</item>
			</outputPins>
			<script><![CDATA[
VSFrustum vsf;
vsf.volumeSize = ivec3($VolumeSize.xyz);
vsf.magicCoeffs = $MagicCoeffs.xy;
vsf.nearZ = $NearZ;
vsf.farZ = $FarZ;

const vec3 ndc = ViewspaceToNDC(vsf, $ViewPosition.xyz);
$Output = vec4(ndc, 0.0f);

$Valid = NDCInRange(ndc) ? 1.0f : 0.0f;

]]></script>
		</item>
