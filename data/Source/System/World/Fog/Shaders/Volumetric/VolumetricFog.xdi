			<inputPins>
				<item>
					<id>{6555AF5E-69B9-2147-A90C-1E6220A22100}</id>
					<name>VolumeSize</name>
				</item>
				<item>
					<id>{79BAF5AF-B891-3D4E-B2E7-CD0F7C03AEC1}</id>
					<name>MagicCoeffs</name>
				</item>
				<item>
					<id>{FEC7D688-4B39-AC46-AF38-B4D6412CFFB3}</id>
					<name>NearZ</name>
				</item>
				<item>
					<id>{ADA5C76A-DB22-EA40-8133-B2A9979C5A07}</id>
					<name>FarZ</name>
				</item>
				<item>
					<id>{D5630BB7-FC83-7640-9DB2-CFB485EFD5A6}</id>
					<name>ViewPosition</name>
				</item>
