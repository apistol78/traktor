				<first>1520</first>
				<second>-35</second>
			</position>
			<name>ViewspaceToFrustumCellNDC</name>
			<technique/>
			<domain>Undefined</domain>
			<localSize>
				<X>1</X>
				<Y>1</Y>
				<Z>1</Z>
			</localSize>
