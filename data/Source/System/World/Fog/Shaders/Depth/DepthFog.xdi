		<item type="traktor.render.Script" version="8,traktor.render.Node:1">
			<id>{E0A9EAF2-632F-40D1-94E5-08FC04377201}</id>
			<comment/>
			<position>
				<first>938</first>
				<second>410</second>
			</position>
			<name>FogFactor</name>
			<technique/>
			<domain>Undefined</domain>
			<localSize>
				<X>1</X>
				<Y>1</Y>
				<Z>1</Z>
			</localSize>
			<useRayTracing>false</useRayTracing>
			<include/>
			<inputPins>
				<item>
					<id>{86BFF8D8-7B18-5A4E-8277-6C6223F5A448}</id>
					<name>Distance</name>
				</item>
				<item>
					<id>{E6A3EC88-1573-4846-9CA5-3CE0EF69A0AF}</id>
					<name>Density</name>
				</item>
				<item>
					<id>{DFB224AC-B176-9B40-9EEA-85B05AC2423D}</id>
					<name>Clamp</name>
				</item>
			</inputPins>
			<outputPins>
				<item>
					<id>{3002126B-3EA9-ED4D-AA78-64F5C94F8E2B}</id>
					<name>Output</name>
					<type>Scalar</type>
				</item>
			</outputPins>
			<script><![CDATA[
			
float t = 1.0f - 1.0f / exp($Distance * $Density);
$Output = clamp(t, 0.0f, $Clamp);
			
			]]></script>
		</item>
