<?xml version="1.0" encoding="utf-8"?>
<object type="traktor.render.ShaderModule" version="2">
	<text><![CDATA[
#define PI 3.142f
#define TWO_PI (PI * 2.0f)
#define HALF_PI (PI / 2.0f)

vec3 TexCoordToDirection(in vec2 texCoord)
{
	float theta = texCoord.x * TWO_PI - PI;
	float phi = texCoord.y * PI;
	float sinPhi = sin(phi);
	return vec3(
		sinPhi * cos(theta),
		cos(phi),
		sinPhi * sin(theta)
	);
}

vec2 DirectionToTexCoord(in vec3 direction)
{
	float u = atan(direction.z, direction.x) / TWO_PI + 0.5f;
	float v = acos(direction.y) / PI;
	return vec2(u, v);
}

]]></text>
	<samplers/>
	<structDeclarations/>
</object>
